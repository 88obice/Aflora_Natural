# ── Copia este archivo como .env y completa los valores ──────────────────
# NUNCA subas .env a GitHub (ya está en .gitignore)

# Django
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Base de datos (desarrollo con variables sueltas)
DB_NAME=aflora_db
DB_USER=postgres
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432

# En producción Railway/Render inyectan DATABASE_URL automáticamente.
# No necesitas las variables sueltas de arriba cuando DATABASE_URL está definida.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Mercado Pago
# Sandbox: usa las claves APP_USR- de tu cuenta de prueba
# Producción: usa las claves de la cuenta vendedora de la dueña
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# Email (Gmail SMTP)
EMAIL_HOST_USER=tu_cuenta@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx   # App Password de Google (no tu contraseña normal)

# Admins que reciben notificaciones de errores Django y nuevos pedidos.
# Si vacio, mail_admins hace fallback a EMAIL_HOST_USER.
ADMIN_NAME=Angel
ADMIN_EMAIL=angelastor2004@gmail.com

# Cloudinary (imágenes en producción)
# Railway: agregar esta variable en el panel Variables del servicio.
# En local: déjala vacía — las imágenes se guardarán en /media/ como siempre.
# Obtener en https://cloudinary.com -> Settings -> API Keys -> "Copy URL"
# Formato: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# Sentry (monitoreo de errores en producción)
# Crear cuenta gratis en https://sentry.io, proyecto Django -> copiar el DSN aquí.
# En desarrollo dejarlo vacío (no se carga si DEBUG=True).
SENTRY_DSN=
ENVIRONMENT=development

# Analytics (solo activos cuando estan definidos — vacios en local, configurados en Railway)
# GA4: analytics.google.com -> propiedad nueva -> Streams -> Measurement ID (G-XXXXXXXXXX)
# Meta Pixel: business.facebook.com -> Events Manager -> Pixels -> ID numerico
GA4_MEASUREMENT_ID=
META_PIXEL_ID=
